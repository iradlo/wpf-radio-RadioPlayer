<Window x:Class="RadioPlayer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RadioPlayer.ViewModels"
        xmlns:conv="clr-namespace:RadioPlayer.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="RadioPlayer"
        Width="900" Height="600"
        MinWidth="680" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="OnWindowPreviewKeyDown">
  <Window.Resources>
    <conv:FaviconConverter x:Key="FaviconConverter" />
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <Style x:Key="NavButtonStyle" TargetType="RadioButton">
      <Setter Property="GroupName" Value="Category" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="#FFD7DCE2" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Root" Background="Transparent"
                    Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="6,2">
              <ContentPresenter VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#FF3A4150" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#FF4458D8" />
                <Setter Property="Foreground" Value="White" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <DockPanel>
    <!-- Player bar (always visible at the bottom) -->
    <Border DockPanel.Dock="Bottom" Background="#FF23272E" Padding="12,8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Current station + now playing -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
          <TextBlock Text="{Binding Player.CurrentStation.Name, FallbackValue='No station selected'}"
                     FontWeight="SemiBold" FontSize="14" Foreground="White" />
          <TextBlock Text="{Binding Player.NowPlaying, StringFormat=' — {0}'}"
                     FontSize="14" Foreground="#FFB9C0CA">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Style.Triggers>
                  <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </Trigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>

        <!-- Transport + volume + status -->
        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Button Grid.Column="0" Content="▶ Play" MinWidth="70" Margin="0,0,6,0"
                  Command="{Binding Player.PlayCommand}"
                  ToolTip="Play the selected station (Space)" />
          <Button Grid.Column="1" Content="⏹ Stop" MinWidth="70" Margin="0,0,18,0"
                  Command="{Binding Player.StopCommand}"
                  ToolTip="Stop playback (Space)" />

          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="🔊" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0" />
            <Slider Width="120" Minimum="0" Maximum="100"
                    Value="{Binding Player.Volume, Mode=TwoWay}"
                    VerticalAlignment="Center"
                    ToolTip="Volume" />
            <TextBlock Text="{Binding Player.Volume, StringFormat={}{0:0}%}"
                       Foreground="#FFB9C0CA" VerticalAlignment="Center"
                       MinWidth="36" Margin="6,0,0,0" />
          </StackPanel>

          <ToggleButton Grid.Column="3" Content="🔇" MinWidth="34" Margin="12,0,0,0"
                        IsChecked="{Binding Player.IsMuted, Mode=TwoWay}"
                        ToolTip="Mute / unmute" />
          <ToggleButton Grid.Column="4" MinWidth="34" Margin="6,0,0,0"
                        IsChecked="{Binding Player.IsCurrentFavorite, Mode=OneWay}"
                        Command="{Binding Player.ToggleFavoriteCommand}"
                        ToolTip="Add to / remove from favorites">
            <ToggleButton.Style>
              <Style TargetType="ToggleButton">
                <Setter Property="Content" Value="☆" />
                <Style.Triggers>
                  <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Content" Value="★" />
                  </Trigger>
                </Style.Triggers>
              </Style>
            </ToggleButton.Style>
          </ToggleButton>

          <TextBlock Grid.Column="5"
                     Text="{Binding Player.StatusText, StringFormat='Status: {0}'}"
                     Foreground="#FFB9C0CA"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Right"
                     TextTrimming="CharacterEllipsis" />
        </Grid>
      </Grid>
    </Border>

    <!-- Station browser -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="180" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Sidebar -->
      <Border Grid.Column="0" Background="#FF2B303B">
        <StackPanel Margin="0,8">
          <RadioButton Style="{StaticResource NavButtonStyle}" Content="⭐  Favorites"
                       Command="{Binding StationList.SelectCategoryCommand}"
                       CommandParameter="{x:Static vm:StationCategory.Favorites}"
                       ToolTip="Your saved stations" />
          <RadioButton Style="{StaticResource NavButtonStyle}" Content="🔥  Popular"
                       IsChecked="True"
                       Command="{Binding StationList.SelectCategoryCommand}"
                       CommandParameter="{x:Static vm:StationCategory.Popular}"
                       ToolTip="Most listened stations" />
          <RadioButton Style="{StaticResource NavButtonStyle}" Content="🌍  By country"
                       x:Name="ByCountryNav"
                       Command="{Binding StationList.SelectCategoryCommand}"
                       CommandParameter="{x:Static vm:StationCategory.ByCountry}"
                       ToolTip="Stations from a specific country" />
          <ComboBox Margin="12,2,12,6"
                    ItemsSource="{Binding StationList.Countries}"
                    SelectedItem="{Binding StationList.SelectedCountry, Mode=TwoWay}"
                    Visibility="{Binding IsChecked, ElementName=ByCountryNav, Converter={StaticResource BoolToVisibility}}"
                    ToolTip="Choose a country" />
          <RadioButton Style="{StaticResource NavButtonStyle}" Content="🎵  By genre"
                       x:Name="ByGenreNav"
                       Command="{Binding StationList.SelectCategoryCommand}"
                       CommandParameter="{x:Static vm:StationCategory.ByGenre}"
                       ToolTip="Stations by music genre" />
          <ComboBox Margin="12,2,12,6"
                    ItemsSource="{Binding StationList.Genres}"
                    SelectedItem="{Binding StationList.SelectedGenre, Mode=TwoWay}"
                    Visibility="{Binding IsChecked, ElementName=ByGenreNav, Converter={StaticResource BoolToVisibility}}"
                    ToolTip="Choose a genre" />
        </StackPanel>
      </Border>

      <!-- Search + list -->
      <Grid Grid.Column="1" Background="#FF1E222A">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Search box -->
        <Grid Grid.Row="0" Margin="10,10,10,4">
          <TextBox x:Name="SearchBox"
                   Padding="8,6"
                   FontSize="13"
                   Background="#FF2B303B"
                   Foreground="White"
                   BorderBrush="#FF3A4150"
                   CaretBrush="White"
                   Text="{Binding StationList.SearchText, UpdateSourceTrigger=PropertyChanged}"
                   ToolTip="Search stations by name (Ctrl+F)" />
          <TextBlock Text="🔍 Search stations..."
                     Margin="10,0,0,0"
                     VerticalAlignment="Center"
                     Foreground="#FF7C8492"
                     IsHitTestVisible="False">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>

        <!-- Notice + loading -->
        <StackPanel Grid.Row="1" Margin="10,0,10,4">
          <TextBlock Text="{Binding StationList.Notice}"
                     Foreground="#FFE5B567"
                     TextWrapping="Wrap"
                     Margin="2,2,2,4">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Style.Triggers>
                  <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </Trigger>
                  <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                  </Trigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
          <ProgressBar Height="3" IsIndeterminate="True"
                       Visibility="{Binding StationList.IsLoading, Converter={StaticResource BoolToVisibility}}" />
        </StackPanel>

        <!-- Station list (virtualized) -->
        <ListView Grid.Row="2"
                  x:Name="StationListView"
                  Margin="10,0,10,10"
                  Background="Transparent"
                  BorderThickness="0"
                  Foreground="White"
                  ItemsSource="{Binding StationList.Stations}"
                  SelectedItem="{Binding StationList.SelectedItem, Mode=TwoWay}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  MouseDoubleClick="OnStationListDoubleClick">
          <ListView.InputBindings>
            <KeyBinding Key="Return" Command="{Binding StationList.PlaySelectedCommand}" />
          </ListView.InputBindings>
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Padding" Value="6,4" />
              <Setter Property="ToolTip" Value="Double-click or press Enter to play" />
            </Style>
          </ListView.ItemContainerStyle>
          <ListView.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:StationItemViewModel}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="32" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="130" />
                  <ColumnDefinition Width="90" />
                  <ColumnDefinition Width="70" />
                  <ColumnDefinition Width="32" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="4"
                        Background="#FF3A4150" VerticalAlignment="Center">
                  <Image Source="{Binding Station.Favicon, Converter={StaticResource FaviconConverter}}"
                         Width="24" Height="24" Stretch="UniformToFill"
                         RenderOptions.BitmapScalingMode="LowQuality" />
                </Border>

                <TextBlock Grid.Column="1" Text="{Binding Station.Name}"
                           FontSize="13" VerticalAlignment="Center"
                           Margin="8,0,4,0" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2" Text="{Binding Station.Country}"
                           Foreground="#FF9AA3B0" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="3" Text="{Binding Station.PrimaryTag}"
                           Foreground="#FF9AA3B0" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="4" Text="{Binding Station.BitrateDisplay}"
                           Foreground="#FF9AA3B0" VerticalAlignment="Center" />

                <ToggleButton Grid.Column="5"
                              IsChecked="{Binding IsFavorite, Mode=OneWay}"
                              Command="{Binding DataContext.StationList.ToggleFavoriteCommand,
                                                RelativeSource={RelativeSource AncestorType=ListView}}"
                              CommandParameter="{Binding}"
                              Background="Transparent" BorderThickness="0"
                              FontSize="14" Cursor="Hand"
                              ToolTip="Add to / remove from favorites">
                  <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                      <Setter Property="Content" Value="☆" />
                      <Setter Property="Foreground" Value="#FF9AA3B0" />
                      <Style.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                          <Setter Property="Content" Value="★" />
                          <Setter Property="Foreground" Value="#FFF0C040" />
                        </Trigger>
                      </Style.Triggers>
                    </Style>
                  </ToggleButton.Style>
                </ToggleButton>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Grid>
    </Grid>
  </DockPanel>
</Window>
